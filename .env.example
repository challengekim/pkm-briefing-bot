# Required
GEMINI_API_KEY=your-gemini-api-key
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Google OAuth2 (run setup_oauth.py to obtain these)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
PERSONAL_GMAIL_REFRESH_TOKEN=your-personal-token
WORK_GMAIL_REFRESH_TOKEN=your-work-token

# LLM API Key
# For Gemini: GEMINI_API_KEY=your-key (https://aistudio.google.com/apikey)
# For OpenRouter: LLM_API_KEY=your-key (https://openrouter.ai/keys)
# For OpenAI: LLM_API_KEY=your-key (https://platform.openai.com/api-keys)
# For Anthropic: LLM_API_KEY=your-key (https://console.anthropic.com/settings/keys)
# For Ollama: no key needed
# LLM_API_KEY=your-api-key

# Optional
PERSONAL_CALENDAR_ID=primary
WORK_CALENDAR_ID=primary

# Config.yaml fallbacks (for deployments without config.yaml)
# NEWSLETTER_SENDERS=Lenny,Superhuman,GeekNews
# KNOWLEDGE_EMAIL_TO=you@example.com

# Railway deployment: persistent storage path for agent state
# Set to /data/compound-brain when using Railway volumes
# COMPOUND_BRAIN_PATH=/data/compound-brain
